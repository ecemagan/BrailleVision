{
  "manifest_version": 3,
  "name": "BrailleVision",
  "version": "1.0",
  "description": "Ekranda seçili matematiksel metinleri Nemeth Braille formatına çevirir.",
  "permissions": ["contextMenus", "activeTab"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "BrailleVision"
  }
}
