{
  "manifest_version": 3,
  "name": "Braille Vision",
  "version": "1.0",
  "description": "Ekranda seçili matematiksel metinleri Nemeth Braille formatına çevirir.",
  "permissions": ["contextMenus", "activeTab"],
  "host_permissions": ["http://localhost:8000/*", "http://127.0.0.1:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Braille Vision",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
